# VerityAI Configuration

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=verityai_password_123

# PostgreSQL (traces, audit logs)
DATABASE_URL=postgresql://verityai_user:verityai_pass_123@localhost:5432/verityai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2:13b

# Z3 (symbolic verification)
Z3_TIMEOUT_SECONDS=3
Z3_MAX_UNKNOWN_ALLOWED=0.2  # 20% of queries allowed to return unknown/timeout

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# LLM Generation
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_RETRY_ATTEMPTS=3

# Verification
VERIFICATION_MAX_ATTEMPTS=3
VERIFICATION_CONFIDENCE_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
